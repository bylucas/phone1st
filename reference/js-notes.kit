<script>
let people = ['peter', 'fred', 'john'];

const ul = document.querySelector('.people');

let html = ``;

people.forEach(person => {
  html += `<li style="color: purple">${person}</li>`;
});

ul.innerHTML = html;

////////////////////

let user = {
  name: 'michael',
  age: 30,
  email: 'michael@michaelcain.co.uk',
  location: 'london',
  blogs: [{title: 'the only way is my way', likes: 30}, {title: 'tomorrow never comes', likes:50}],

  login: function(){
   document.getElementById("demo7").innerHTML = 'the user logged in';
  },
  
  logout: function(){
   document.getElementById("demo8").innerHTML = 'the user logged out';
  },
  
  logBlogs(){
// access the blogs here
   console.log(this);
   console.log('this user has written these blogs:');

const ul = document.querySelector('.blogs');

let html = ``;

document.getElementById("demo9").innerHTML = 'this user has written these blogs:';

this.blogs.forEach(blog => {
html += `<li style="color: red">${blog.title} has ${blog.likes} likes</li>`; 
})
ul.innerHTML = html;
}
};

user.logBlogs();

/////////////////////////

const content = document.querySelector('.contenta');
content.innerHTML = '<h2>this is a new h2</h2>';

content.innerHTML += '<h2>this is an h2 added to the content</h2>';

const crowd = ['john', 'fred', 'mike'];

crowd.forEach(person => {
content.innerHTML += `<p>${person}</p>`;
});
const link = document.querySelector('.contentb a');

link.setAttribute('href', 'https://phone1st.org');
link.textContent = 'The Phone1st website';

const mssg = document.querySelector('.contentb h3');

mssg.setAttribute('class', 'success');
mssg.setAttribute('style', 'color: green');

const title = document.querySelector('.contentc h4');

title.style.margin = '50px';
title.style.color = 'crimson';
title.style.fontSize = '60px';
title.style.margin = '';

const story = document.querySelectorAll('.contentd p');

story.forEach(p => {
  if(p.textContent.includes('error')){
    p.classList.add('error');
  } else if(p.textContent.includes('success')) {
    p.classList.add('success');
  }
});

const button = document.querySelector('.contente button');

 button.addEventListener('click', () => {
   document.getElementById("contente").innerHTML = 'you clicked me';
 });

 const items = document.querySelectorAll('.items li');

items.forEach(item => {
  item.addEventListener('click', e => {
    console.log('item clicked');
    console.log(e);
    console.log(e.target);
    console.log(item);
    e.target.style.textDecoration = 'line-through';
  });
});

const ul2 = document.querySelector('.list');

const button2 = document.querySelector('.button');

button2.addEventListener('click', () => {
  const li = document.createElement('li');
  li.textContent = 'something new to do';
  ul2.prepend(li);
});

const list = document.querySelectorAll('.list', 'li');

list.forEach(li => {
  li.addEventListener('click', e => {
    e.target.remove();
  });
});

const box = document.querySelector('.boxed');

box.addEventListener('mousemove', e => {
  //console.log(e.offsetX, e.offsetY);
  box.textContent = `x pos - ${e.offsetX}  y pos - ${e.offsetY}`;
});

const submit = document.querySelector('.popup-button');
const popup = document.querySelector('.popup-wrapper');
const close = document.querySelector('.popup-close');

submit.addEventListener('click', () => {
  popup.style.display = 'block';
});

close.addEventListener('click', () => {
  popup.style.display = 'none';
});

popup.addEventListener('click', (e) => {
  if(e.target.className === 'popup-wrapper'){
    popup.style.display = 'none';
  }
});

</script>

