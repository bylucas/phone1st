
 <div class="post-meta-header">
 
<div class="post-meta">Stored in <span class="author"><a href="<!-- $cat-url -->"><!-- $cat --></a></span> | Written on<span class="author"><!-- $date --></span></div>

 <div class="post-meta-header-share">
		<div class="post-meta-header-share-label">Share
		</div>
		<a class="post-meta-header-share-tw" href="https://twitter.com/share?text=<!-- $title -->&amp;url=https://phone1st.org/<!-- $url -->" onclick="window.open(this.href, 'share-twitter', 'width=550,height=235');return false;">
			<!-- @import ../icons/twitter.kit -->
		</a>
		<a class="post-meta-header-share-fb" href="https://www.facebook.com/sharer/sharer.php?u=https://phone1st.org/<!-- $url -->" onclick="window.open(this.href, 'share-facebook','width=580,height=296');return false;">
			<!-- @import ../icons/facebook.kit -->
		</a>
		<a class="post-meta-header-share-li" href="https://www.linkedin.com/shareArticle?mini=true&amp;url=https://phone1st.org/<!-- $url -->/&amp;title=<!-- $title -->" onclick="window.open(this.href, 'share-linkedin','width=930,height=720');return false;">
			<!-- @import ../icons/linkedin2.kit -->
		</a>
		<a class="post-meta-header-share-em" href="mailto:?subject=Interesting%20Article%20from%20Phone1st&amp;body=https://phone1st.org/<!-- $url -->%20take%20a%20look">
			<!-- @import ../icons/mail.kit -->
		</a>
	</div>
	</div>
