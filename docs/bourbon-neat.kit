    <a href="#value">Value Prefixer</a>
    <a href="#grids">Grids</a>
  </div>
  </div>
<hr>
        
<h2 id="border-color">Border Color</h2>
<pre><code class="lang-scss">.element {
@include border-color($error-color $alert-color null $success-color);
}</code></pre>
        
<div class="mixin-box one"></div>
<hr>
<h2 id="border-radius">Border Radius</h2>
<pre><code class="lang-scss">.element {
@include border-top-radius(8px);
@include border-bottom-radius(15px);
}</code></pre>
        
<div class="mixin-box two"></div>

<pre><code class="lang-scss">.element {
@include border-right-radius(8px);
@include border-left-radius(15px);
}</code></pre>

<div class="mixin-box two-a"></div>
<hr>
<h2 id="border-style">Border Style</h2>
<pre><code class="lang-scss">.element {
@include border-style(dashed double solid dotted);
}</code></pre>
        
<div class="mixin-box three"></div>
<hr>
<h2 id="border-width">Border Width</h2>
<pre><code class="lang-scss">.element {
@include border-width(1em 2rem 25px 20px);
}</code></pre>
        
<div class="mixin-box four"></div>
<hr>
<h2 id="buttons">Buttons</h2>
<pre><code class="lang-scss">#{$all-buttons} {
background-color: #f00;
}
//CSS Output
button,
[type='button'],
[type='reset'],
[type='submit'] {
background-color: #f00;
}
#{$all-buttons-active} {
background-color: #00f;
}
//CSS Output
button:active,
[type='button']:active,
[type='reset']:active,
[type='submit']:active {
background-color: #00f;
}
#{$all-buttons-focus} {
background-color: #0f0;
}
//CSS Output
button:focus,
[type='button']:focus,
[type='reset']:focus,
[type='submit']:focus {
background-color: #00f;
}
#{$all-buttons-hover} {
background-color: #0f0;
}
//CSS Output
button:hover,
[type='button']:hover,
[type='reset']:hover,
[type='submit']:hover {
background-color: #00f;
}</code></pre>
<hr>
<h2 id="clearfix">Clearfix</h2>
<pre><code class="lang-scss">.element {
@include clearfix;
}
//CSS Output
.element::after {
clear: both;
content: "";
display: block;
}</code></pre>
<hr>
<h2 id="contrast">Contrast Switch</h2>
<p>Switches between two colors based on the contrast to another color.<br><em>See css/bourbon5/bourbon/library/_contrast-switch.scss</em></p>
<pre><code class="lang-scss">.element {
$button-color: #2d72d9;
background-color: $button-color;
color: contrast-switch($button-color, #222, #eee);
}</code></pre>
        
<div class="mixin-box five">
<p>Color Contrast Switch</p>
</div>
<hr>
<h2 id="ellipsis">Ellipsis</h2>
<pre><code class="lang-scss">.element {
@include ellipsis;
}</code></pre>
        
<div class="six">
Lorem ipsum dolor sit amet, consectetur adipisicing elit. Sed cumque at soluta molestiae laudantium saepe iure rem corporis neque quas ullam inventore vel sunt dolor consequatur, quam, tempore optio. Error.
</div>
